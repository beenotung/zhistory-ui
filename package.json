{
  "name": "zhistory-ui",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "",
  "keywords": [],
  "author": {
    "name": "Beeno Tung",
    "email": "aabbcc1241@yahoo.com.hk",
    "url": "https://beeno-tung.surge.sh"
  },
  "license": "BSD-2-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beenotung/zhistory-ui.git"
  },
  "homepage": "https://github.com/beenotung/zhistory-ui#readme",
  "bugs": {
    "url": "https://github.com/beenotung/zhistory-ui/issues"
  },
  "main": "dist/core.js",
  "types": "dist/core.d.ts",
  "browser": "dist/core.js",
  "exports": {
    ".": {
      "import": "./dist/core.js",
      "require": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./fs": {
      "import": "./dist/fs.js",
      "require": "./dist/fs.js",
      "types": "./dist/fs.d.ts"
    }
  },
  "bin": {
    "zhistory-cli": "cli-bin.js",
    "zhistory-webui": "webui-bin.js"
  },
  "files": [
    "dist",
    "cli-bin.js",
    "webui-bin.js"
  ],
  "scripts": {
    "test": "tsc --noEmit",
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc -p . && rimraf dist/tsconfig.tsbuildinfo dist/*.test.d.ts dist/*.test.js dist/*.spec.d.ts dist/*.spec.js dist/cli.d.ts dist/web-ui.d.ts",
    "tsc": "tsc -p .",
    "dev": "tsc -p . --watch"
  },
  "dependencies": {
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
